  { "id": 217, "chapter": "Chapter 10: Biotechnology and its Applications", "question": "The Bt toxin protein exist as inactive protoxins but once an insect ingest the inactive toxin, it is converted into an active form of toxin due to the alkaline pH of the gut which solubilise the crystals.", "options": ["Acidic pH", "Alkaline pH of gut", "Neutral", "Only presence of food"], "answer": 1, "difficulty": "medium" },
  { "id": 218, "chapter": "Chapter 10: Biotechnology and its Applications", "question": "The activated toxin binds to the surface of midgut epithelial cells and create pores that cause cell swelling and lysis and eventually cause death of the insect.", "options": ["No death", "Binds to midgut, creates pores, cell swell and lysis", "Only in brain", "Only in wings"], "answer": 1, "difficulty": "medium" },
