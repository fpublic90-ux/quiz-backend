  { "id": 215, "chapter": "Chapter 10: Biotechnology and its Applications", "question": "Some strains of Bacillus thuringiensis produce proteins that kill certain insects such as lepidopterans, coleopterans and dipterans.", "options": ["Only butterflies", "Lepidopterans, coleopterans, dipterans", "Only flies", "Only beetles"], "answer": 1, "difficulty": "medium" },
