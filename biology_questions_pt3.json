  { "id": 204, "chapter": "Chapter 2: Human Reproduction", "question": "During follicular phase, primary follicles in ovary grow and secretory phase follows.", "options": ["No growth", "Primary follicles grow", "Only one follicle", "Only in luteal"], "answer": 1, "difficulty": "medium" },
  { "id": 205, "chapter": "Chapter 2: Human Reproduction", "question": "Ovulation occurs at the middle of menstrual cycle due to LH surge.", "options": ["No LH", "LH surge", "Estrogen only", "Progesterone only"], "answer": 1, "difficulty": "medium" },
  { "id": 206, "chapter": "Chapter 2: Human Reproduction", "question": "Corpus luteum secretes large amounts of progesterone which is essential for maintenance of endometrium.", "options": ["Estrogen", "Progesterone", "LH", "FSH"], "answer": 1, "difficulty": "medium" },
  { "id": 207, "chapter": "Chapter 2: Human Reproduction", "question": "In humans, sperm - ovum fusion occurs only if sperm and ovum are transported simultaneously to the ampullary region.", "options": ["Uterus", "Ampullary region", "Cervix", "Vagina"], "answer": 1, "difficulty": "medium" },
  { "id": 208, "chapter": "Chapter 2: Human Reproduction", "question": "The process of fusion of a sperm with an ovum is called fertilisation.", "options": ["Implantation", "Fertilisation", "Gametogenesis", "Parturition"], "answer": 1, "difficulty": "easy" },
  { "id": 209, "chapter": "Chapter 2: Human Reproduction", "question": "During fertilisation, a sperm comes in contact with the zona pellucida layer of the ovum.", "options": ["Corona radiata", "Zona pellucida", "Plasma membrane", "Nucleus"], "answer": 1, "difficulty": "medium" },
  { "id": 210, "chapter": "Chapter 2: Human Reproduction", "question": "The secretions of the acrosome help the sperm enter into the cytoplasm of the ovum through the zona pellucida and the plasma membrane.", "options": ["Mitochondria", "Acrosome", "Tail", "Nucleus"], "answer": 1, "difficulty": "medium" },
  { "id": 211, "chapter": "Chapter 2: Human Reproduction", "question": "This induces the completion of meiotic division of the secondary oocyte.", "options": ["Mitotic", "Meiotic division", "No division", "Only cleavage"], "answer": 1, "difficulty": "medium" },
  { "id": 212, "chapter": "Chapter 2: Human Reproduction", "question": "The second meiotic division is also unequal and results in the formation of a second polar body and a haploid ovum.", "options": ["Equal", "Unequal, second polar body and haploid ovum", "Two polar bodies", "Two ova"], "answer": 1, "difficulty": "medium" },
  { "id": 213, "chapter": "Chapter 2: Human Reproduction", "question": "The haploid nucleus of the sperm and that of the ovum fuse together to form a diploid zygote.", "options": ["Haploid zygote", "Diploid zygote", "Triploid", "No fusion"], "answer": 1, "difficulty": "easy" },
